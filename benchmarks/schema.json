{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BenchmarkCase",
  "description": "gh-verify benchmark case definition",
  "type": "object",
  "required": ["id", "description", "repo", "pr_number", "expected", "rationale", "category", "domains_expected", "ecosystem"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^((pass|warn|error)-\\d{3}|[a-z0-9]+(?:-[a-z0-9]+)*)$",
      "description": "Stable case ID. Legacy severity-prefixed IDs remain valid, but new cases should use descriptive slugs."
    },
    "description": {
      "type": "string",
      "description": "One-line description of what this PR demonstrates"
    },
    "repo": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_.-]+/[a-zA-Z0-9_.-]+$",
      "description": "GitHub owner/repo"
    },
    "pr_number": {
      "type": "integer",
      "minimum": 1
    },
    "expected": {
      "type": "string",
      "enum": ["pass", "warning", "error"],
      "description": "Expected severity that gh-verify should return"
    },
    "rationale": {
      "type": "string",
      "description": "Rationale for expected value (call-graph connectivity analysis)"
    },
    "category": {
      "type": "string",
      "enum": [
        "single-file",
        "connected-calls",
        "connected-imports",
        "disconnected-test",
        "disconnected-components",
        "multi-component",
        "semantic-bridge",
        "fork-sync",
        "non-code-only",
        "single-domain",
        "ci-only",
        "test-only",
        "docs-plus-feature",
        "noise-threshold",
        "multi-domain-warn",
        "multi-domain-error",
        "conflict-imports",
        "clean-single-domain",
        "path-only-fallback"
      ]
    },
    "domains_expected": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Legacy field. Set to [] for call-graph based cases."
    },
    "ecosystem": {
      "type": "string",
      "description": "Language/framework: go, rust, typescript, python, ruby, etc."
    },
    "notes": {
      "type": "string",
      "description": "Known classification quirks, false positives/negatives, and other notes"
    },
    "source": {
      "type": "object",
      "description": "Optional provenance for cases curated from external datasets such as OSS Insight.",
      "required": ["provider"],
      "properties": {
        "provider": {
          "type": "string",
          "description": "Source provider name, e.g. ossinsight"
        },
        "collection_id": {
          "type": "integer",
          "description": "OSS Insight collection ID used during discovery"
        },
        "collection_name": {
          "type": "string",
          "description": "Human-readable collection name"
        },
        "selection": {
          "type": "string",
          "description": "How this PR was selected into the benchmark set"
        },
        "discovered_at": {
          "type": "string",
          "description": "UTC timestamp when the source record was discovered"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
