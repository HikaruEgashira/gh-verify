{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BenchmarkCase",
  "description": "ghlint benchmark case definition",
  "type": "object",
  "required": ["id", "description", "repo", "pr_number", "expected", "rationale", "category", "domains_expected", "ecosystem"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(pass|warn|error)-\\d{3}$",
      "description": "Unique ID in format: pass-001, warn-002, error-003"
    },
    "description": {
      "type": "string",
      "description": "One-line description of what this PR demonstrates"
    },
    "repo": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_.-]+/[a-zA-Z0-9_.-]+$",
      "description": "GitHub owner/repo"
    },
    "pr_number": {
      "type": "integer",
      "minimum": 1
    },
    "expected": {
      "type": "string",
      "enum": ["pass", "warning", "error"],
      "description": "Expected severity that ghlint should return"
    },
    "rationale": {
      "type": "string",
      "description": "Rationale for expected value (which files map to which domains)"
    },
    "category": {
      "type": "string",
      "enum": [
        "single-domain",
        "ci-only",
        "test-only",
        "docs-plus-feature",
        "noise-threshold",
        "multi-domain-warn",
        "multi-domain-error",
        "conflict-imports",
        "clean-single-domain",
        "path-only-fallback"
      ]
    },
    "domains_expected": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["auth", "ui", "database", "docs", "ci", "config", "api"]
      },
      "description": "Active domains ghlint should detect (test/unknown excluded)"
    },
    "ecosystem": {
      "type": "string",
      "description": "Language/framework: go, rust, typescript, python, ruby, etc."
    },
    "notes": {
      "type": "string",
      "description": "Known classification quirks, false positives/negatives, and other notes"
    }
  },
  "additionalProperties": false
}
