{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BenchmarkCase",
  "description": "ghlint ベンチマークケース定義",
  "type": "object",
  "required": ["id", "description", "repo", "pr_number", "expected", "rationale", "category", "domains_expected", "ecosystem"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(pass|warn|error)-\\d{3}$",
      "description": "一意のID: pass-001, warn-002, error-003 形式"
    },
    "description": {
      "type": "string",
      "description": "このPRが何をデモするかの1行説明"
    },
    "repo": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_.-]+/[a-zA-Z0-9_.-]+$",
      "description": "GitHub owner/repo"
    },
    "pr_number": {
      "type": "integer",
      "minimum": 1
    },
    "expected": {
      "type": "string",
      "enum": ["pass", "warning", "error"],
      "description": "ghlintが返すべき severity"
    },
    "rationale": {
      "type": "string",
      "description": "期待値の根拠（どのファイルがどのドメインに分類されるか）"
    },
    "category": {
      "type": "string",
      "enum": [
        "single-domain",
        "ci-only",
        "test-only",
        "docs-plus-feature",
        "noise-threshold",
        "multi-domain-warn",
        "multi-domain-error"
      ]
    },
    "domains_expected": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["auth", "ui", "database", "docs", "ci", "config", "api"]
      },
      "description": "ghlintが検出すべきアクティブドメイン（test/unknownは除外）"
    },
    "ecosystem": {
      "type": "string",
      "description": "言語/フレームワーク: go, rust, typescript, python, ruby等"
    },
    "notes": {
      "type": "string",
      "description": "既知の分類クセ、false positive/negative、その他注意点"
    }
  },
  "additionalProperties": false
}
